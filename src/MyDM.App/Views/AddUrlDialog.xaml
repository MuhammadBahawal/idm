<Window x:Class="MyDM.App.Views.AddUrlDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Download File Info" Width="860" Height="430"
        MinWidth="760" MinHeight="390"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip"
        Background="#ECECEC" FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#F2F2F2"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="BorderBrush" Value="#A8A8A8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,7"/>
            <Setter Property="MinWidth" Value="165"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="PrimaryActionButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="BorderBrush" Value="#1D7AE6"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#ECECEC" BorderBrush="#C7C7C7" BorderThickness="1" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="125"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="URL" Style="{StaticResource FieldLabel}"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" x:Name="UrlTextBox"
                             Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}" FontSize="14"
                             Padding="6,4" BorderBrush="#B6B6B6" BorderThickness="1"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Category" Style="{StaticResource FieldLabel}"/>
                    <ComboBox Grid.Row="2" Grid.Column="1" x:Name="CategoryCombo" FontSize="14" Padding="4,3" BorderBrush="#B6B6B6" BorderThickness="1">
                        <ComboBoxItem Content="Auto-detect" IsSelected="True"/>
                        <ComboBoxItem Content="Video"/>
                        <ComboBoxItem Content="Music"/>
                        <ComboBoxItem Content="Documents"/>
                        <ComboBoxItem Content="Programs"/>
                        <ComboBoxItem Content="Compressed"/>
                        <ComboBoxItem Content="Others"/>
                    </ComboBox>
                    <Button Grid.Row="2" Grid.Column="2" Content="+" Width="34" Height="30" Margin="8,0,0,0"
                            Style="{StaticResource ActionButton}" IsEnabled="False"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Save As" Style="{StaticResource FieldLabel}"/>
                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="SavePathTextBox" FontSize="14" Padding="6,4" BorderBrush="#B6B6B6" BorderThickness="1"/>
                    <Button Grid.Row="4" Grid.Column="2" Content="..." Width="38" Height="30" Margin="8,0,0,0"
                            Style="{StaticResource ActionButton}" Click="BrowseFolder_Click"/>

                    <CheckBox Grid.Row="5" Grid.Column="1" Margin="0,8,0,0"
                              Content="Remember this path for selected category" FontSize="13" Foreground="#222222"/>

                    <Border Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2" Background="#EFEFEF" BorderBrush="#D0D0D0" BorderThickness="1" Padding="8" Margin="0,0,0,0">
                        <TextBlock Text="{Binding ElementName=SavePathTextBox, Path=Text}" FontSize="13" Foreground="#4D4D4D" TextTrimming="CharacterEllipsis"/>
                    </Border>

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Description" Style="{StaticResource FieldLabel}" Margin="0,8,0,0"/>
                    <TextBox Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="2" x:Name="DescriptionTextBox" Margin="0,8,0,0"
                             FontSize="14" Padding="6,4" BorderBrush="#B6B6B6" BorderThickness="1"/>

                    <!-- keep these controls for logic compatibility -->
                    <TextBox x:Name="FileNameTextBox" Visibility="Collapsed"/>
                    <ComboBox x:Name="ConnectionsCombo" Visibility="Collapsed">
                        <ComboBoxItem Content="1"/>
                        <ComboBoxItem Content="2"/>
                        <ComboBoxItem Content="4"/>
                        <ComboBoxItem Content="8" IsSelected="True"/>
                        <ComboBoxItem Content="16"/>
                        <ComboBoxItem Content="32"/>
                    </ComboBox>
                </Grid>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Media" FontSize="26" Foreground="#EF7C22" HorizontalAlignment="Center"/>
                    <TextBlock Text="-- MB" FontSize="32" Margin="0,12,0,0" Foreground="#111111" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,14,0,0">
            <Button Content="Download Later" Style="{StaticResource ActionButton}" Click="AddPaused_Click" Margin="0,0,14,0"/>
            <Button Content="Start Download" Style="{StaticResource PrimaryActionButton}" Click="StartDownload_Click" Margin="0,0,14,0"/>
            <Button Content="Cancel" Style="{StaticResource ActionButton}" Click="Cancel_Click" MinWidth="130"/>
        </StackPanel>
    </Grid>
</Window>
