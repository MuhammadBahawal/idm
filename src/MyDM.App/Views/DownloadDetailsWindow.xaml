<Window x:Class="MyDM.App.Views.DownloadDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:MyDM.App.Utilities"
        Title="{Binding WindowTitle}" Height="560" Width="860" MinHeight="500" MinWidth="760"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Background" Value="{StaticResource ChunkCardBrush}"/>
            <Setter Property="BorderBrush" Value="#E2E9F4"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Margin" Value="0,3,0,0"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="12" Padding="12"
                Background="{StaticResource PanelCardBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Width="36" Height="36" CornerRadius="18" Background="#E8F0FD" BorderBrush="#CBDCF7" BorderThickness="1"
                        VerticalAlignment="Top">
                    <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="Realtime Download Monitor" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock Text="{Binding FileName}" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Url}" FontSize="10.5" Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <Border Grid.Column="2" VerticalAlignment="Center" Padding="11,6"
                        CornerRadius="999" Background="{Binding StatusBadgeBrush}">
                    <TextBlock Text="{Binding StatusText}" FontSize="11.5" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"/>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="0,8,0,0" CornerRadius="12" Padding="12"
                Background="{StaticResource PanelCardBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Overall Progress" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock Grid.Column="1" Text="{Binding ProgressText}" FontSize="12" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"/>
                </Grid>

                <ProgressBar Maximum="100"
                             Height="10"
                             Margin="0,6,0,0"
                             ui:ProgressBarAnimationHelper.TargetValue="{Binding ProgressPercent, Mode=OneWay}"/>

                <UniformGrid Columns="3" Margin="0,10,0,0">
                    <Border Style="{StaticResource MetricCardStyle}">
                        <StackPanel>
                            <TextBlock Text="File Size" Style="{StaticResource MetricLabelStyle}"/>
                            <TextBlock Text="{Binding FileSizeText}" Style="{StaticResource MetricValueStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource MetricCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Downloaded" Style="{StaticResource MetricLabelStyle}"/>
                            <TextBlock Text="{Binding DownloadedText}" Style="{StaticResource MetricValueStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource MetricCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Speed" Style="{StaticResource MetricLabelStyle}"/>
                            <TextBlock Text="{Binding TransferRateText}" Style="{StaticResource MetricValueStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource MetricCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Remaining" Style="{StaticResource MetricLabelStyle}"/>
                            <TextBlock Text="{Binding TimeLeftText}" Style="{StaticResource MetricValueStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource MetricCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Connections" Style="{StaticResource MetricLabelStyle}"/>
                            <TextBlock Text="{Binding ConnectionsText}" Style="{StaticResource MetricValueStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Resume Support" Style="{StaticResource MetricLabelStyle}"/>
                            <TextBlock Text="{Binding ResumeCapabilityText}" Style="{StaticResource MetricValueStyle}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.7*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="12" Padding="10"
                    Background="{StaticResource PanelCardBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Per-Connection Progress" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                    <ListView Grid.Row="1" ItemsSource="{Binding SegmentRows}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="#" Width="30" DisplayMemberBinding="{Binding Index}"/>
                                <GridViewColumn Header="Range" Width="140" DisplayMemberBinding="{Binding RangeText}"/>
                                <GridViewColumn Header="Downloaded" Width="98" DisplayMemberBinding="{Binding DownloadedText}"/>
                                <GridViewColumn Header="Speed" Width="90" DisplayMemberBinding="{Binding SpeedText}"/>
                                <GridViewColumn Header="Status" Width="82" DisplayMemberBinding="{Binding StatusText}"/>
                                <GridViewColumn Header="Progress" Width="128">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid Width="118">
                                                <ProgressBar Maximum="100"
                                                             Height="6"
                                                             ui:ProgressBarAnimationHelper.TargetValue="{Binding ProgressPercent, Mode=OneWay}"/>
                                                <TextBlock Text="{Binding ProgressText}" FontSize="9.5" Margin="0,7,0,0"
                                                           HorizontalAlignment="Center" Foreground="{StaticResource TextMutedBrush}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Column="2" CornerRadius="12" Padding="10"
                    Background="{StaticResource PanelCardBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Live Logs" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                    <ListBox Grid.Row="1" ItemsSource="{Binding LogEntries}" FontFamily="Cascadia Mono"
                             FontSize="10.5" BorderThickness="0" Background="Transparent"
                             Foreground="{StaticResource TextMutedBrush}"/>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Margin="0,8,0,0" CornerRadius="12" Padding="10"
                Background="{StaticResource PanelCardBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="True" VerticalAlignment="Center">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Speed Limit (KB/s)" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,8,0"/>
                        <TextBox Width="95" Text="{Binding SpeedLimitInput, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                        <Button Content="Apply" Style="{StaticResource ToolbarButton}" Margin="8,0,0,0"
                                Padding="12,7" Click="ApplySpeedLimit_Click"/>
                    </StackPanel>

                    <TextBlock Text="{Binding SpeedLimitStatusText}" Margin="12,0,0,0"
                               VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}"/>
                </DockPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="{Binding PauseResumeButtonText}" Style="{StaticResource PrimaryButton}"
                            IsEnabled="{Binding CanPauseResume}" Margin="0,0,8,0" Padding="16,8"
                            Click="PauseResume_Click"/>
                    <Button Content="Cancel" Style="{StaticResource DangerButton}" Padding="16,8"
                            Margin="0,0,8,0" IsEnabled="{Binding CanCancel}" Click="CancelDownload_Click"/>
                    <Button Content="Close" Style="{StaticResource ToolbarButton}" Padding="16,8"
                            Click="Close_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
