<Window x:Class="MyDM.App.Views.DownloadDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:MyDM.App.Utilities"
        Title="{Binding WindowTitle}" Height="680" Width="980" MinHeight="600" MinWidth="860"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}"
        FontFamily="Segoe UI">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="12" Padding="14"
                Background="{StaticResource PanelCardBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Download Progress" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock Text="{Binding FileName}" FontSize="19" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Url}" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <Border Grid.Column="1" VerticalAlignment="Center" Padding="12,7"
                        CornerRadius="999" Background="{Binding StatusBadgeBrush}">
                    <TextBlock Text="{Binding StatusText}" FontSize="12" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"/>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="0,10,0,0" CornerRadius="12" Padding="14"
                Background="{StaticResource PanelCardBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="File Size" Style="{StaticResource MetaLabelText}"/>
                        <TextBlock Text="{Binding FileSizeText}" Style="{StaticResource MetaValueText}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="Downloaded" Style="{StaticResource MetaLabelText}"/>
                        <TextBlock Text="{Binding DownloadedText}" Style="{StaticResource MetaValueText}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,12,0">
                        <TextBlock Text="Speed" Style="{StaticResource MetaLabelText}"/>
                        <TextBlock Text="{Binding TransferRateText}" Style="{StaticResource MetaValueText}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3">
                        <TextBlock Text="Remaining Time" Style="{StaticResource MetaLabelText}"/>
                        <TextBlock Text="{Binding TimeLeftText}" Style="{StaticResource MetaValueText}"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Overall Progress" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock Grid.Column="1" Text="{Binding ProgressText}" FontSize="12" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"/>
                </Grid>

                <ProgressBar Maximum="100"
                             Height="12"
                             Margin="0,6,0,0"
                             ui:ProgressBarAnimationHelper.TargetValue="{Binding ProgressPercent, Mode=OneWay}"/>

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Resume Support" Style="{StaticResource MetaLabelText}"/>
                        <TextBlock Text="{Binding ResumeCapabilityText}" Style="{StaticResource MetaValueText}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="Connections" Style="{StaticResource MetaLabelText}"/>
                        <TextBlock Text="{Binding ConnectionsText}" Style="{StaticResource MetaValueText}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,12,0">
                        <TextBlock Text="Category" Style="{StaticResource MetaLabelText}"/>
                        <TextBlock Text="{Binding CategoryText}" Style="{StaticResource MetaValueText}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3">
                        <TextBlock Text="Status" Style="{StaticResource MetaLabelText}"/>
                        <TextBlock Text="{Binding StatusText}" Style="{StaticResource MetaValueText}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="12" Padding="10"
                    Background="{StaticResource PanelCardBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Per-Connection Progress" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                    <ListView Grid.Row="1" ItemsSource="{Binding SegmentRows}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="#" Width="34" DisplayMemberBinding="{Binding Index}"/>
                                <GridViewColumn Header="Range" Width="170" DisplayMemberBinding="{Binding RangeText}"/>
                                <GridViewColumn Header="Downloaded" Width="120" DisplayMemberBinding="{Binding DownloadedText}"/>
                                <GridViewColumn Header="Speed" Width="105" DisplayMemberBinding="{Binding SpeedText}"/>
                                <GridViewColumn Header="Status" Width="95" DisplayMemberBinding="{Binding StatusText}"/>
                                <GridViewColumn Header="Progress" Width="150">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid Width="140">
                                                <ProgressBar Maximum="100"
                                                             Height="7"
                                                             ui:ProgressBarAnimationHelper.TargetValue="{Binding ProgressPercent, Mode=OneWay}"/>
                                                <TextBlock Text="{Binding ProgressText}" FontSize="10" Margin="0,8,0,0"
                                                           HorizontalAlignment="Center" Foreground="{StaticResource TextMutedBrush}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Column="2" CornerRadius="12" Padding="10"
                    Background="{StaticResource PanelCardBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Live Logs" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                    <ListBox Grid.Row="1" ItemsSource="{Binding LogEntries}" FontFamily="Cascadia Mono"
                             FontSize="11" BorderThickness="0" Background="Transparent"
                             Foreground="{StaticResource TextMutedBrush}"/>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Margin="0,10,0,0" CornerRadius="12" Padding="10"
                Background="{StaticResource PanelCardBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Speed Limit (KB/s)" VerticalAlignment="Center"
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" Text="{Binding SpeedLimitInput, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                <Button Grid.Column="2" Content="Apply" Style="{StaticResource ToolbarButton}" Margin="8,0,0,0"
                        Padding="14,8" Click="ApplySpeedLimit_Click"/>

                <TextBlock Grid.Column="3" Text="{Binding SpeedLimitStatusText}" Margin="14,0,0,0"
                           VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}"/>

                <Button Grid.Column="4" Content="{Binding PauseResumeButtonText}" Style="{StaticResource PrimaryButton}"
                        IsEnabled="{Binding CanPauseResume}" Margin="0,0,8,0" Padding="18,8"
                        Click="PauseResume_Click"/>
                <Button Grid.Column="5" Content="Cancel" Style="{StaticResource DangerButton}" Padding="18,8"
                        Margin="0,0,8,0" IsEnabled="{Binding CanCancel}" Click="CancelDownload_Click"/>
                <Button Grid.Column="6" Content="Close" Style="{StaticResource ToolbarButton}" Padding="18,8"
                        Click="Close_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>

