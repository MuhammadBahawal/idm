<Window x:Class="MyDM.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MyDM - Download Manager"
        Icon="/app.ico"
        Height="760"
        Width="1260"
        MinWidth="1020"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <SolidColorBrush x:Key="TitleChipBrush" Color="#E7F0FF"/>
        <SolidColorBrush x:Key="TitleChipBorderBrush" Color="#C9DBFA"/>

        <Style TargetType="Menu">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="9,4"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="ShellToolbarButton" TargetType="Button">
            <Setter Property="Width" Value="94"/>
            <Setter Property="Height" Value="82"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#F7FAFF"/>
            <Setter Property="BorderBrush" Value="#D6E1F1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Background" Value="#EDF4FF"/>
                                <Setter TargetName="ButtonRoot" Property="BorderBrush" Value="#BFD4F5"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Background" Value="#E0ECFD"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CategoryTreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="Margin" Value="4,1,0,1"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E4EEFF"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DownloadGridHeaderStyle" TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#F2F6FC"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="9,7"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style x:Key="DownloadRowStyle" TargetType="ListViewItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#E7ECF4"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="4,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="2">
                            <GridViewRowPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#F1F6FF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#DDEAFF"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="268" MinWidth="220"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="3" CornerRadius="14" Padding="14"
                Background="{StaticResource PanelCardBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="MyDM Download Manager" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="Fast, segmented desktop downloads with queue and extension integration"
                               Margin="0,4,0,0" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border CornerRadius="10" Background="{StaticResource TitleChipBrush}" BorderBrush="{StaticResource TitleChipBorderBrush}"
                            BorderThickness="1" Padding="10,5" Margin="0,0,8,0">
                        <TextBlock Text="{Binding ActiveDownloadsText}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                    </Border>
                    <Border CornerRadius="10" Background="#E5F3F1" BorderBrush="#C5E3DE" BorderThickness="1" Padding="10,5">
                        <TextBlock Text="{Binding TotalSpeedText}" FontWeight="SemiBold" Foreground="#1D7068"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Grid.RowSpan="2" Margin="0,10,0,0" CornerRadius="14"
                Background="{StaticResource PanelCardBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="12,10" BorderBrush="#E6ECF5" BorderThickness="0,0,0,1">
                    <TextBlock Text="Download Categories" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"/>
                </Border>

                <TreeView x:Name="CategoryTree"
                          Margin="10"
                          Background="Transparent"
                          BorderThickness="0"
                          SelectedItemChanged="CategoryTree_SelectedItemChanged"
                          ItemContainerStyle="{StaticResource CategoryTreeItemStyle}">
                    <TreeViewItem IsExpanded="True" Tag="All Downloads">
                        <TreeViewItem.Header>
                            <TextBlock Text="All Downloads" FontWeight="SemiBold"/>
                        </TreeViewItem.Header>
                        <TreeViewItem Header="Compressed" Tag="Compressed"/>
                        <TreeViewItem Header="Documents" Tag="Documents"/>
                        <TreeViewItem Header="Music" Tag="Music"/>
                        <TreeViewItem Header="Programs" Tag="Programs"/>
                        <TreeViewItem Header="Video" Tag="Video"/>
                        <TreeViewItem Header="Others" Tag="Others"/>
                    </TreeViewItem>

                    <TreeViewItem IsExpanded="True" Tag="Unfinished">
                        <TreeViewItem.Header>
                            <TextBlock Text="Unfinished" FontWeight="SemiBold"/>
                        </TreeViewItem.Header>
                        <TreeViewItem Header="Compressed" Tag="Compressed"/>
                        <TreeViewItem Header="Documents" Tag="Documents"/>
                        <TreeViewItem Header="Music" Tag="Music"/>
                        <TreeViewItem Header="Programs" Tag="Programs"/>
                        <TreeViewItem Header="Video" Tag="Video"/>
                    </TreeViewItem>

                    <TreeViewItem IsExpanded="True" Tag="Finished">
                        <TreeViewItem.Header>
                            <TextBlock Text="Finished" FontWeight="SemiBold"/>
                        </TreeViewItem.Header>
                        <TreeViewItem Header="Compressed" Tag="Compressed"/>
                        <TreeViewItem Header="Documents" Tag="Documents"/>
                        <TreeViewItem Header="Music" Tag="Music"/>
                        <TreeViewItem Header="Programs" Tag="Programs"/>
                        <TreeViewItem Header="Video" Tag="Video"/>
                    </TreeViewItem>

                    <TreeViewItem IsExpanded="True" Tag="Queues">
                        <TreeViewItem.Header>
                            <TextBlock Text="Queues" FontWeight="SemiBold"/>
                        </TreeViewItem.Header>
                        <TreeViewItem Header="Main download queue" Tag="Queues"/>
                    </TreeViewItem>
                </TreeView>
            </DockPanel>
        </Border>

        <GridSplitter Grid.Row="1"
                      Grid.RowSpan="2"
                      Grid.Column="1"
                      Width="6"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Stretch"
                      Margin="0,10,0,0"
                      Background="#D6DEEA"
                      ShowsPreview="True"/>

        <Border Grid.Row="1" Grid.Column="2" Margin="0,10,0,0" CornerRadius="14" Padding="10"
                Background="{StaticResource PanelCardBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Menu Grid.Row="0">
                    <MenuItem Header="Tasks">
                        <MenuItem Header="Add URL" Command="{Binding AddUrlCommand}"/>
                        <Separator/>
                        <MenuItem Header="Exit" Click="ExitMenu_Click"/>
                    </MenuItem>
                    <MenuItem Header="File">
                        <MenuItem Header="Settings" Command="{Binding OpenSettingsCommand}"/>
                    </MenuItem>
                    <MenuItem Header="Downloads">
                        <MenuItem Header="Resume" Command="{Binding ResumeSelectedCommand}"/>
                        <MenuItem Header="Stop" Command="{Binding StopSelectedCommand}"/>
                        <MenuItem Header="Stop All" Command="{Binding StopAllCommand}"/>
                        <MenuItem Header="Delete Selected" Click="DeleteSelected_Click"/>
                        <MenuItem Header="Details" Command="{Binding ShowDetailsCommand}"/>
                    </MenuItem>
                    <MenuItem Header="View">
                        <MenuItem Header="All Downloads" Click="AllDownloadsMenu_Click"/>
                    </MenuItem>
                    <MenuItem Header="Help">
                        <MenuItem Header="About" Click="AboutMenu_Click"/>
                    </MenuItem>
                    <MenuItem Header="Registration"/>
                </Menu>

                <ScrollViewer Grid.Row="1" Margin="0,8,0,0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource ShellToolbarButton}" Command="{Binding AddUrlCommand}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE710;" FontSize="25" Foreground="#2A9E62" HorizontalAlignment="Center"/>
                                <TextBlock Text="Add URL" FontSize="11" Margin="0,5,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource ShellToolbarButton}" Command="{Binding ResumeSelectedCommand}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE768;" FontSize="25" Foreground="#2F6FED" HorizontalAlignment="Center"/>
                                <TextBlock Text="Resume" FontSize="11" Margin="0,5,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource ShellToolbarButton}" Command="{Binding StopSelectedCommand}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE71A;" FontSize="25" Foreground="#B45D5D" HorizontalAlignment="Center"/>
                                <TextBlock Text="Stop" FontSize="11" Margin="0,5,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource ShellToolbarButton}" Command="{Binding StopAllCommand}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE711;" FontSize="25" Foreground="#986E49" HorizontalAlignment="Center"/>
                                <TextBlock Text="Stop All" FontSize="11" Margin="0,5,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource ShellToolbarButton}" Click="DeleteSelected_Click" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74D;" FontSize="25" Foreground="#B24A6D" HorizontalAlignment="Center"/>
                                <TextBlock Text="Delete" FontSize="11" Margin="0,5,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource ShellToolbarButton}" Command="{Binding OpenSettingsCommand}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" FontSize="25" Foreground="#5966B9" HorizontalAlignment="Center"/>
                                <TextBlock Text="Options" FontSize="11" Margin="0,5,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource ShellToolbarButton}" Command="{Binding StartQueueCommand}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE768;" FontSize="25" Foreground="#1D8A84" HorizontalAlignment="Center"/>
                                <TextBlock Text="Start Queue" FontSize="11" Margin="0,5,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource ShellToolbarButton}" Command="{Binding StopQueueCommand}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE71A;" FontSize="25" Foreground="#B37033" HorizontalAlignment="Center"/>
                                <TextBlock Text="Stop Queue" FontSize="11" Margin="0,5,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource ShellToolbarButton}" Command="{Binding ShowDetailsCommand}">
                            <StackPanel>
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE946;" FontSize="25" Foreground="#5F63A8" HorizontalAlignment="Center"/>
                                <TextBlock Text="Details" FontSize="11" Margin="0,5,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="2" Grid.Column="2" Margin="0,10,0,0" CornerRadius="14"
                Background="{StaticResource PanelCardBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="12,10" BorderBrush="#E6ECF5" BorderThickness="0,0,0,1">
                    <TextBlock Text="Downloads" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"/>
                </Border>

                <ListView Grid.Row="1"
                          x:Name="DownloadList"
                          Margin="0"
                          BorderThickness="0"
                          Background="Transparent"
                          ItemsSource="{Binding Downloads}"
                          SelectedItem="{Binding SelectedDownload, Mode=TwoWay}"
                          SelectionMode="Extended"
                          ItemContainerStyle="{StaticResource DownloadRowStyle}"
                          KeyDown="DownloadList_KeyDown"
                          MouseDoubleClick="DownloadList_DoubleClick"
                          ScrollViewer.CanContentScroll="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListView.View>
                        <GridView ColumnHeaderContainerStyle="{StaticResource DownloadGridHeaderStyle}">
                            <GridViewColumn Header="File Name" Width="260" DisplayMemberBinding="{Binding FileName}"/>
                            <GridViewColumn Header="Q" Width="30" DisplayMemberBinding="{Binding Item.Connections}"/>
                            <GridViewColumn Header="Size" Width="98" DisplayMemberBinding="{Binding SizeText}"/>
                            <GridViewColumn Header="Status" Width="200" DisplayMemberBinding="{Binding StatusText}"/>
                            <GridViewColumn Header="Time Left" Width="95" DisplayMemberBinding="{Binding TimeLeftText}"/>
                            <GridViewColumn Header="Speed" Width="108" DisplayMemberBinding="{Binding SpeedText}"/>
                            <GridViewColumn Header="Last Try" Width="125" DisplayMemberBinding="{Binding LastTryText}"/>
                            <GridViewColumn Header="Description" Width="300" DisplayMemberBinding="{Binding DescriptionText}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <Border Grid.Row="3" Grid.ColumnSpan="3" Margin="0,10,0,0" CornerRadius="12" Padding="10,8"
                Background="{StaticResource PanelCardBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1">
            <DockPanel LastChildFill="True">
                <TextBlock Text="{Binding StatusBarText}" FontSize="12" VerticalAlignment="Center" DockPanel.Dock="Left"
                           Foreground="{StaticResource TextMutedBrush}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding ActiveDownloadsText}" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,14,0"/>
                    <TextBlock Text="{Binding TotalSpeedText}" Foreground="#1D8A84" FontWeight="SemiBold"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
