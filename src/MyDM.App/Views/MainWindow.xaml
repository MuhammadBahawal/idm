<Window x:Class="MyDM.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MyDM - Download Manager"
        Height="740"
        Width="1240"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="#F2F2F2"
        FontFamily="Tahoma"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <SolidColorBrush x:Key="ClassicBorderBrush" Color="#B7B7B7"/>
        <SolidColorBrush x:Key="ClassicPanelBrush" Color="#F9F9F9"/>
        <SolidColorBrush x:Key="ClassicHeaderBrush" Color="#EFEFEF"/>
        <SolidColorBrush x:Key="ClassicHoverBrush" Color="#EAF2FF"/>
        <SolidColorBrush x:Key="ClassicSelectBrush" Color="#0078D7"/>

        <Style TargetType="Menu">
            <Setter Property="Background" Value="{StaticResource ClassicPanelBrush}"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="4,1"/>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Foreground" Value="#111111"/>
        </Style>

        <Style x:Key="IdmToolbarButton" TargetType="Button">
            <Setter Property="Width" Value="86"/>
            <Setter Property="Height" Value="78"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Background" Value="{StaticResource ClassicHoverBrush}"/>
                                <Setter TargetName="ButtonRoot" Property="BorderBrush" Value="#9AB6D8"/>
                                <Setter Property="Foreground" Value="#111111"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Background" Value="#DCE9F7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ClassicTreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="Padding" Value="1"/>
            <Setter Property="Margin" Value="0,1,0,1"/>
        </Style>

        <Style x:Key="ClassicGridHeaderStyle" TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{StaticResource ClassicHeaderBrush}"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="#C9C9C9"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style x:Key="ClassicRowStyle" TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E2E2"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="4,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <GridViewRowPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource ClassicHoverBrush}"/>
                                <Setter Property="Foreground" Value="#111111"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource ClassicSelectBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource ClassicPanelBrush}" BorderBrush="{StaticResource ClassicBorderBrush}" BorderThickness="0,0,0,1">
            <Menu>
                <MenuItem Header="Tasks">
                    <MenuItem Header="Add URL" Command="{Binding AddUrlCommand}"/>
                    <Separator/>
                    <MenuItem Header="Exit" Click="ExitMenu_Click"/>
                </MenuItem>
                <MenuItem Header="File">
                    <MenuItem Header="Settings" Command="{Binding OpenSettingsCommand}"/>
                </MenuItem>
                <MenuItem Header="Downloads">
                    <MenuItem Header="Resume" Command="{Binding ResumeSelectedCommand}"/>
                    <MenuItem Header="Stop" Command="{Binding StopSelectedCommand}"/>
                    <MenuItem Header="Stop All" Command="{Binding StopAllCommand}"/>
                    <MenuItem Header="Delete Selected" Click="DeleteSelected_Click"/>
                    <MenuItem Header="Details" Command="{Binding ShowDetailsCommand}"/>
                </MenuItem>
                <MenuItem Header="View">
                    <MenuItem Header="All Downloads" Click="AllDownloadsMenu_Click"/>
                </MenuItem>
                <MenuItem Header="Help">
                    <MenuItem Header="About" Click="AboutMenu_Click"/>
                </MenuItem>
                <MenuItem Header="Registration"/>
            </Menu>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource ClassicPanelBrush}" BorderBrush="{StaticResource ClassicBorderBrush}" BorderThickness="0,0,0,1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal" Margin="4,2">
                    <Button Style="{StaticResource IdmToolbarButton}" Command="{Binding AddUrlCommand}">
                        <StackPanel>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE710;" FontSize="30" Foreground="#3BA66B" HorizontalAlignment="Center"/>
                            <TextBlock Text="Add URL" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource IdmToolbarButton}" Command="{Binding ResumeSelectedCommand}">
                        <StackPanel>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE768;" FontSize="30" Foreground="#89A6C9" HorizontalAlignment="Center"/>
                            <TextBlock Text="Resume" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource IdmToolbarButton}" Command="{Binding StopSelectedCommand}">
                        <StackPanel>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE71A;" FontSize="30" Foreground="#A7A7A7" HorizontalAlignment="Center"/>
                            <TextBlock Text="Stop" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource IdmToolbarButton}" Command="{Binding StopAllCommand}">
                        <StackPanel>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE711;" FontSize="30" Foreground="#9B9B9B" HorizontalAlignment="Center"/>
                            <TextBlock Text="Stop All" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource IdmToolbarButton}" Click="DeleteSelected_Click">
                        <StackPanel>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74D;" FontSize="30" Foreground="#D96AA6" HorizontalAlignment="Center"/>
                            <TextBlock Text="Delete" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource IdmToolbarButton}" Command="{Binding OpenSettingsCommand}">
                        <StackPanel>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" FontSize="30" Foreground="#6B79CC" HorizontalAlignment="Center"/>
                            <TextBlock Text="Options" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource IdmToolbarButton}" Command="{Binding StartQueueCommand}">
                        <StackPanel>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE768;" FontSize="30" Foreground="#5A9CCF" HorizontalAlignment="Center"/>
                            <TextBlock Text="Start Queue" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource IdmToolbarButton}" Command="{Binding StopQueueCommand}">
                        <StackPanel>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE71A;" FontSize="30" Foreground="#835FC7" HorizontalAlignment="Center"/>
                            <TextBlock Text="Stop Queue" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource IdmToolbarButton}" Command="{Binding ShowDetailsCommand}">
                        <StackPanel>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE946;" FontSize="30" Foreground="#7F82C8" HorizontalAlignment="Center"/>
                            <TextBlock Text="Details" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="220"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="{StaticResource ClassicBorderBrush}" BorderThickness="0,0,1,0" Background="#F7F7F7">
                <TreeView x:Name="CategoryTree"
                          Margin="6,6,4,6"
                          SelectedItemChanged="CategoryTree_SelectedItemChanged"
                          ItemContainerStyle="{StaticResource ClassicTreeItemStyle}">
                    <TreeViewItem IsExpanded="True" Tag="All Downloads">
                        <TreeViewItem.Header>
                            <TextBlock Text="All Downloads"/>
                        </TreeViewItem.Header>
                        <TreeViewItem Header="   Compressed" Tag="Compressed"/>
                        <TreeViewItem Header="   Documents" Tag="Documents"/>
                        <TreeViewItem Header="   Music" Tag="Music"/>
                        <TreeViewItem Header="   Programs" Tag="Programs"/>
                        <TreeViewItem Header="   Video" Tag="Video"/>
                        <TreeViewItem Header="   Others" Tag="Others"/>
                    </TreeViewItem>

                    <TreeViewItem IsExpanded="True" Tag="Unfinished">
                        <TreeViewItem.Header>
                            <TextBlock Text="Unfinished"/>
                        </TreeViewItem.Header>
                        <TreeViewItem Header="   Compressed" Tag="Compressed"/>
                        <TreeViewItem Header="   Documents" Tag="Documents"/>
                        <TreeViewItem Header="   Music" Tag="Music"/>
                        <TreeViewItem Header="   Programs" Tag="Programs"/>
                        <TreeViewItem Header="   Video" Tag="Video"/>
                    </TreeViewItem>

                    <TreeViewItem IsExpanded="True" Tag="Finished">
                        <TreeViewItem.Header>
                            <TextBlock Text="Finished"/>
                        </TreeViewItem.Header>
                        <TreeViewItem Header="   Compressed" Tag="Compressed"/>
                        <TreeViewItem Header="   Documents" Tag="Documents"/>
                        <TreeViewItem Header="   Music" Tag="Music"/>
                        <TreeViewItem Header="   Programs" Tag="Programs"/>
                        <TreeViewItem Header="   Video" Tag="Video"/>
                    </TreeViewItem>

                    <TreeViewItem IsExpanded="True" Tag="Queues">
                        <TreeViewItem.Header>
                            <TextBlock Text="Queues"/>
                        </TreeViewItem.Header>
                        <TreeViewItem Header="   Main download queue" Tag="Queues"/>
                    </TreeViewItem>
                </TreeView>
            </Border>

            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#D0D0D0"
                          ShowsPreview="True"/>

            <Border Grid.Column="2" Background="White">
                <ListView x:Name="DownloadList"
                          Margin="0"
                          BorderThickness="0"
                          ItemsSource="{Binding Downloads}"
                          SelectedItem="{Binding SelectedDownload, Mode=TwoWay}"
                          SelectionMode="Extended"
                          ItemContainerStyle="{StaticResource ClassicRowStyle}"
                          KeyDown="DownloadList_KeyDown"
                          MouseDoubleClick="DownloadList_DoubleClick"
                          ScrollViewer.CanContentScroll="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListView.View>
                        <GridView ColumnHeaderContainerStyle="{StaticResource ClassicGridHeaderStyle}">
                            <GridViewColumn Header="File Name" Width="260" DisplayMemberBinding="{Binding FileName}"/>
                            <GridViewColumn Header="Q" Width="26" DisplayMemberBinding="{Binding Item.Connections}"/>
                            <GridViewColumn Header="Size" Width="96" DisplayMemberBinding="{Binding SizeText}"/>
                            <GridViewColumn Header="Status" Width="190" DisplayMemberBinding="{Binding StatusText}"/>
                            <GridViewColumn Header="Time left" Width="96" DisplayMemberBinding="{Binding TimeLeftText}"/>
                            <GridViewColumn Header="Transfer rate" Width="110" DisplayMemberBinding="{Binding SpeedText}"/>
                            <GridViewColumn Header="Last Try..." Width="120" DisplayMemberBinding="{Binding LastTryText}"/>
                            <GridViewColumn Header="Description" Width="320" DisplayMemberBinding="{Binding DescriptionText}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>
        </Grid>

        <Border Grid.Row="3" BorderBrush="{StaticResource ClassicBorderBrush}" BorderThickness="0,1,0,0" Background="{StaticResource ClassicPanelBrush}">
            <DockPanel LastChildFill="True" Margin="6,4">
                <TextBlock Text="{Binding StatusBarText}" FontSize="12" VerticalAlignment="Center" DockPanel.Dock="Left" Foreground="#444444"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding ActiveDownloadsText}" Foreground="#444444" Margin="0,0,16,0"/>
                    <TextBlock Text="{Binding TotalSpeedText}" Foreground="#1D8A84"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
